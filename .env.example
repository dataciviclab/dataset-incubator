# dataset-incubator — Environment Variables
# Copia in .env solo se serve sovrascrivere i default.

# GitHub Token — per script che creano issue/PR tramite API
# GITHUB_TOKEN=ghp_abc123...

# Clean Query MCP — path del catalogo e cache
# CLEAN_QUERY_CATALOG_PATH=registry/clean_catalog.json
# CLEAN_QUERY_GCS_CACHE_TTL=300
# CLEAN_QUERY_GCS_AUTH=auto       # auto|true|false

# Google Cloud Storage — per push_archive.py (CI principalmente)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/sa.json
